# Recordings (gameplay captures kept out of git to keep the repo lean)
[Rr]ecordings/

# Asset meta data should only be ignored when the corresponding asset is also
# ignored — keep all .meta files for tracked assets.
!/[Aa]ssets/**/*.meta

